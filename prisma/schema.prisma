generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Bảng 1: Người dùng
model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  fullname      String         
  role          String         @default("viewer") 
  permissions   String[]       @default(["CHAT", "CONV_C", "CONV_R", "CONV_U", "CONV_D"]) 
  conversations Conversation[]
  groups        Group[]        @relation("UserGroups")
  acls          ACL[]          
  createdAt     DateTime       @default(now())
}

// Bảng 2: Nhóm
model Group {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions String[] @default([])
  users       User[]   @relation("UserGroups")
  acls        ACL[]    
}

// Bảng 3: Hội thoại (để quản lý chat)
model Conversation {
  id        Int      @id @default(autoincrement())
  title     String
  messages  Json     @default("[]") 
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

// BẢNG 4: Danh sách kiểm soát truy cập (Access Control List)
model ACL {
  id           Int    @id @default(autoincrement())
  userId       Int?   // Quyền cấp riêng cho từng cá nhân (để trống nếu cấp cho Group)
  groupId      Int?   // Quyền cấp cho cả một nhóm (để trống nếu cấp cho User)
  resourceType String // Loại đối tượng: "Group", "User", "Conversation"
  resourceId   Int    // ID cụ thể của đối tượng đó trong DB (ví dụ: groupId = 5)
  action       String // Hành động: "READ", "WRITE", "DELETE", "MANAGE"
  user         User?  @relation(fields: [userId], references: [id])
  group        Group? @relation(fields: [groupId], references: [id])
  @@unique([userId, resourceType, resourceId, action])
  @@unique([groupId, resourceType, resourceId, action])
}